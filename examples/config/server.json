{
  "log": {
    "access": {
      "level": "info",
      "path": "log/server_access.log"
    }
  },
  "inbound": {
    "protocol": "ethan",//入站类型
    "port": 10800,//服务端监听端口
    "uid": "",//服务端认证用户
    "pwd": "",//服务单认证密码
    "tls": {
      "crt_path": "",//服务端tls证书 认证连+公钥路径
      "key_path": "",//服务端tls 私钥路径
      "domain_name": ""//服务端域名地址
    }
  },
  //出站
  "outbounds": [
    {
      "protocol": "direct", 
      "name": "direct"
    }
  ],
  "routes": [
    {
      "to": "direct",
      "rule": "*",
      "rule_type":"default"
    }
  ]
}